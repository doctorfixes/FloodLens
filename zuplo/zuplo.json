{
  "routes": [
    {
      "path": "/v1/determine-zone",
      "method": "POST",
      "label": "Flood Zone Determination",
      "handler": {
        "module": "$import(@zuplo/runtime)",
        "export": "urlRewriteHandler",
        "options": {
          "rewritePattern": "${env.SUPABASE_FUNCTION_URL}/determine-zone",
          "forwardSearch": false
        }
      },
      "policies": {
        "inbound": [
          "api-key-inbound",
          "rate-limit-inbound",
          "request-validation-inbound"
        ],
        "outbound": [
          "stripe-metered-billing-outbound"
        ]
      }
    }
  ]
}
