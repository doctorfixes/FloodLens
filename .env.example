# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_DB_URL=postgres://postgres:password@db.your-project.supabase.co:5432/postgres

# Geocoding fallback (required only when Census geocoder fails)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe (consumed by Zuplo billing hook - not by the Edge Function)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_METERED_PRICE_ID=price_...

# Zuplo
SUPABASE_FUNCTION_URL=https://your-project.supabase.co/functions/v1
