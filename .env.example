# Required — Supabase project credentials
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_PROJECT_ID=<your-project-id>
SUPABASE_DB_PASSWORD=<your-database-password>

# Optional — Google Maps Geocoding API key (fallback geocoder)
# If not set, only the Census geocoder is used.
GOOGLE_MAPS_API_KEY=

# Required — Stripe secret key for metered billing
STRIPE_SECRET_KEY=sk_live_...

# Required — PostgreSQL connection string for DAG ingestion
DATABASE_URL=postgres://postgres:<password>@db.<project-id>.supabase.co:5432/postgres

# Optional — Override data directory for shapefile storage (default: data/)
DATA_DIR=data

# Optional — NFHL dataset date for download_nfhl.sh (default: 20231001)
# Format: YYYYMMDD. Check https://hazards.fema.gov/nfhl for the latest date.
NFHL_DATE=20231001
